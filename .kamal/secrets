# Secrets defined here are available for reference under registry/password, env/secret, builder/secrets,
# and accessories/*/env/secret in config/deploy.yml. All secrets should be pulled from either
# password manager, ENV, or a file. DO NOT ENTER RAW CREDENTIALS HERE! This file needs to be safe for git.

# This file is safe to commit. Real values live in the gitignored
# .kamal/secrets.local file and are validated by .kamal/hooks/pre-connect.
RAILS_MASTER_KEY=$(cat config/master.key)

KAMAL_REGISTRY_PASSWORD=$(ruby -rdotenv -e 'print Dotenv.parse(".kamal/secrets.local").fetch("KAMAL_REGISTRY_PASSWORD")')
DATABASE_URL=$(ruby -rdotenv -e 'print Dotenv.parse(".kamal/secrets.local").fetch("DATABASE_URL")')
SMTP_PASSWORD=$(ruby -rdotenv -e 'print Dotenv.parse(".kamal/secrets.local").fetch("SMTP_PASSWORD")')
