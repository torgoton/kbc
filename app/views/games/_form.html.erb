<%= form_with(model: game) do |form| %>
  <% if game.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(game.errors.count, "error") %> prohibited this game from being saved:</h2>

      <ul>
        <% game.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <label for="game_speed">Speed</label>
    <%= form.select :speed, [
      [ "Untimed", "" ],
      [ "Blitz — 3 min + 15 s/turn", "blitz" ],
      [ "Normal — 10 min + 30 s/turn", "normal" ]
    ] %>
    <button type="button" onclick="this.nextElementSibling.showModal()" aria-label="What is a timed game?">?</button>
    <dialog>
      <h3>Timed games</h3>
      <p>Each player gets a time bank that only drains on their own turn, plus a small increment credited each time they end their turn (Fischer clock) — so slow play only costs the slow player.</p>
      <p>Your clock doesn't start until your first move of the game; think as long as you like before that.</p>
      <p>If your bank runs out, you're <strong>flagged</strong>: the game doesn't end automatically, but any opponent can claim victory.</p>
      <p>Untimed and abandoned timed tables are cleaned up automatically after a period of inactivity.</p>
      <%# No <form method="dialog"> here: it would nest inside the game form,
          nested forms are invalid HTML, and the parser drops the inner tag —
          making Close submit the game form. Plain type="button" instead. %>
      <button type="button" onclick="this.closest('dialog').close()">Close</button>
    </dialog>
    <%= form.submit %>
  </div>
<% end %>
