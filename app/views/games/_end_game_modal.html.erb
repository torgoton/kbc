<dialog id="end-game-modal" open>
  <h2>Game Over!</h2>
  <% winners = game.winners %>
  <p class="winner-declaration">
    <% if winners.size == 1 %>
      <%= winners.first.player.handle %> wins!
    <% else %>
      Tie: <%= winners.map { |w| w.player.handle }.to_sentence %> share the victory!
    <% end %>
  </p>
  <% players = game.game_players.sort_by(&:order) %>
  <% goal_keys = Array(scores&.values).compact.flat_map(&:keys).uniq - ["total"] %>
  <% if scores.present? %>
    <table class="score-table">
      <thead>
        <tr>
          <th>Goal</th>
          <% players.each do |player| %>
            <th class="score-value"><%= player.player.handle %></th>
          <% end %>
        </tr>
      </thead>
      <tbody>
        <% goal_keys.each do |goal| %>
          <tr>
            <td><%= goal.capitalize %></td>
            <% players.each do |player| %>
              <td class="score-value"><%= scores.dig(player.order.to_s, goal, "score").to_i %></td>
            <% end %>
          </tr>
        <% end %>
        <tr class="score-total">
          <td>Total</td>
          <% players.each do |player| %>
            <td class="score-value"><%= scores[player.order.to_s]["total"] %></td>
          <% end %>
        </tr>
        <% if players.all?(&:rating_after) %>
          <tr class="rating-row">
            <td>Rating</td>
            <% players.each do |player| %>
              <% delta = player.rating_after - player.rating_before %>
              <td class="score-value">
                <%= player.rating_before %> &rarr; <%= player.rating_after %>
                (<%= delta >= 0 ? "+" : "" %><%= delta %>)
              </td>
            <% end %>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% end %>
  <form method="dialog"><button>Close</button></form>
</dialog>
