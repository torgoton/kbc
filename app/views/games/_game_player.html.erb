<% my_turn = n == 0 && player.id == game.current_player&.id %>
<div class="player-info-zone">
  <div class="player-header">
    <%= content_tag :div, class: "handle #{' my-turn' if my_turn }" do %>
      <% if player.id == game.current_player&.id %>
        <%= content_tag :span, class: "player-spinner" do %>
          <%= image_tag "tape-reel.svg", title: "It's your turn" %>
        <% end %>
      <% end %>
      <%= player.player.handle %>
      <span class="rating-badge">(<%= rating_badge(player.player) %>)</span>
      <% if player.order == 0 %>
        <%= content_tag :span, class: "first-player-marker", title: "First player" do %>
          <%= image_tag "first.svg", alt: "First player" %>
        <% end %>
      <% end %>
    <% end %>
    <% score_data = local_assigns.fetch(:scores, nil)&.dig(player.order.to_s) %>
    <% if score_data %>
      <div class="score-container">
        <div class="player-score"><%= score_data["total"] %> <span class="score-unit">pts</span></div>
        <div class="score-breakdown">
          <% score_data.except("total").each do |goal_key, result| %>
            <div class="score-row">
              <span class="score-goal-name"><%= goal_key.capitalize %></span>
              <span class="score-goal-value"><%= result[:score] %></span>
            </div>
          <% end %>
          <div class="score-row score-row-total">
            <span class="score-goal-name">Total</span>
            <span class="score-goal-value"><%= score_data["total"] %></span>
          </div>
        </div>
      </div>
    <% end %>
    <% if n == 0 && game.id %>
      <%= button_to("Undo", undo_move_game_path(game), class: "undo-btn", disabled: !(my_turn && engine.undo_allowed?)) %>
    <% end %>
  </div>
  <div class="player-stats">
    <% display_cards = (n == 0 || game.current_player_id == player.id) ? Array(player.hand) : Array(player.hand).map { "Z" } %>
    <% chosen = (game.current_player_id == player.id) ? game.current_action["chosen_terrain"] : nil %>
    <% display_cards.each do |card| %>
      <% shunned = chosen && card != chosen %>
      <%= content_tag :span, card, title: Boards::Board::TERRAIN_NAMES[card], class: "player-card card-#{card}#{" card-shunned" if shunned}" %>
    <% end %>
    <% fort_terrain = (game.current_player_id == player.id) ? game.current_action["fort_terrain"] : nil %>
    <% if fort_terrain %>
      <span class="fort-drawn" title="Fort drew <%= Boards::Board::TERRAIN_NAMES[fort_terrain] %>">
        <span class="fort-drawn-label">Fort drew</span>
        <%= content_tag :span, fort_terrain, class: "player-card card-#{fort_terrain}" %>
      </span>
    <% end %>
    <div class="supply-display">
      <div class="supply-settlements">
        <%= content_tag :span, player.supply["settlements"], class: "settlement-count" %>
        <%= render "games/settlement", color: player_color(player.order), css_class: "settlement-icon" %>
      </div>
      <% player.warriors_remaining.times do %>
        <%= render "games/warrior", color: player_color(player.order), css_class: "warrior-icon" %>
      <% end %>
      <% player.ships_remaining.times do %>
        <%= render "games/ship", color: player_color(player.order), css_class: "warrior-icon" %>
      <% end %>
      <% player.wagons_remaining.times do %>
        <%= render "games/wagon", color: player_color(player.order), css_class: "warrior-icon" %>
      <% end %>
    </div>
  </div>
</div>
<div class="player-action-zone">
  <%= render partial: "games/tiles", locals: { game:, player:, n:, engine:, my_turn: } if game.id %>
</div>
