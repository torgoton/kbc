<h2>My Games</h2>
<% games.each do |game| %>
  <div class="game-row <%= 'my-turn' if game.my_turn?(Current.user) %>">
    <% if game.playing? %>
      <%= link_to game_path(game), class: "game-row" do %>
        <div>Game <%= game.id %> &mdash; <%= game.turn_state %></div>
        <div class="player-handles">Players: <%= game.player_handles %></div>
      <% end %>
    <% else %>
      <div>Game <%= game.id %> &mdash; <%= game.turn_state %></div>
      <div class="player-handles">Players: <%= game.player_handles %></div>
    <% end %>
  </div>
  <br/>
<% end %>
<br/>
<%= link_to "Open a new table", new_game_path %>
