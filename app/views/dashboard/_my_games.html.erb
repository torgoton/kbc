<h2>My Games</h2>
<% games.each do |game| %>
  <div class="game-row <%= 'my-turn' if game.my_turn?(Current.user) %>">
    <% if game.playing? %>
      <span class="pulser">
        <% if game.my_turn?(Current.user) %>
          ●
        <% else %>
          &nbsp;
        <% end %>
      </span>
      <%= link_to game_path(game) do %>
        <span>
          Game <%= game.id %> with <%= game.player_handles %> &mdash; <%= game.turn_state %>
        </span>
      <% end %>
    <% else %>
      <span>
        Game <%= game.id %> with <%= game.player_handles %> &mdash; <%= game.turn_state %>
      </span>
    <% end %>
  </div>
  <br/>
<% end %>
<br/>
<h3><%= link_to "Open a new table", new_game_path %></h3>
