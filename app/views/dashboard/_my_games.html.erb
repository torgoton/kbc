<h2>My Games</h2>
<% games.each do |game| %>
  <% if game.playing? %>
    <%= link_to game_path(game), class: "game-row" do %>
      <div>Game <%= game.id %> &mdash; <%= game.turn_state %></div>
      <div class="player-handles">
        Players:
        <%= game.game_players.map { |gp| gp.player.handle }.join(", ") %>
      </div>
    <% end %>
  <% else %>
    <div class="game-row">
      <div>Game <%= game.id %> &mdash; Waiting for players</div>
      <div class="player-handles">
        Players:
        <%= game.game_players.map { |gp| gp.player.handle }.join(", ") %>
      </div>
    </div>
  <% end %>
<% end %>
